# App
APP_NAME=online-exam-system
APP_ENV=local
APP_PORT=8080
FRONTEND_PORT=5173

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=exam_system
DB_USERNAME=root
DB_PASSWORD=change_me

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=replace_with_local_secret
JWT_EXPIRE_SECONDS=7200
JWT_ISSUER=exam-system-local

# Storage
STORAGE_TYPE=local
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# Mail
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=

# SMS
SMS_PROVIDER=
SMS_ACCESS_KEY=
SMS_SECRET_KEY=

# Monitoring
ENABLE_METRICS=true
ENABLE_HEALTHCHECK=true

# AI
AI_API_BASE_URL=
AI_API_KEY=
AI_MODEL=

# Backend profile
SPRING_PROFILES_ACTIVE=mysql

# Frontend
VITE_API_BASE_URL=http://localhost:8083
